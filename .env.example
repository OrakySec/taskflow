# ─────────────────────────────────────────────────────────────
# TASKFLOW — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────

# ── Banco de Dados ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:SENHA_AQUI@localhost:5432/taskflow"

# ── NextAuth.js ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-um-secret-com-openssl-rand-base64-32"

# ── MinIO (Storage) ─────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="taskflow"
MINIO_SECRET_KEY="SENHA_MINIO_AQUI"
MINIO_BUCKET="taskflow"
MINIO_USE_SSL="false"

# ── Resend (E-mail) ─────────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"
RESEND_FROM="TaskFlow <no-reply@ykaromarques.com>"

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TaskFlow"

# ── Cron (segurança dos endpoints) ──────────────────────────
CRON_SECRET="gere-um-secret-aleatorio-aqui"
