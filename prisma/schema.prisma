// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MULTI-TENANT: Empresa (Tenant)
// ─────────────────────────────────────────────
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  clients            Client[]
  tasks              Task[]
  templates          TaskTemplate[]
  notificationConfig NotificationConfig?
  invites            Invite[]
  recurringTasks     RecurringTask[]
  teams              Team[]

  @@map("companies")
}

// ─────────────────────────────────────────────
// USUÁRIOS
// ─────────────────────────────────────────────
enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  COLLABORATOR
  CLIENT
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  role      UserRole @default(COLLABORATOR)
  avatar    String?
  phone     String?
  notifyWhatsapp Boolean @default(false)
  notifyTelegram Boolean @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedTasks          Task[]          @relation("AssignedTasks")
  createdTasks           Task[]          @relation("CreatedTasks")
  comments               TaskComment[]
  notifications          Notification[]
  badges                 UserBadge[]
  taskHistories          TaskHistory[]
  assignedRecurring      RecurringTask[] @relation("RecurringAssignee")
  createdRecurring       RecurringTask[] @relation("RecurringCreator")
  teams                  Team[]          @relation("TeamMembers")

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([email, companyId])
  @@map("users")
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  role      UserRole @default(COLLABORATOR)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("invites")
}

// ─────────────────────────────────────────────
// EQUIPES (TEAMS)
// ─────────────────────────────────────────────
model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  members     User[]   @relation("TeamMembers")
  tasks       Task[]   @relation("TeamTasks")

  @@map("teams")
}

// ─────────────────────────────────────────────
// CLIENTES
// ─────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tasks          Task[]
  recurringTasks RecurringTask[]
  users          User[]

  @@map("clients")
}

// ─────────────────────────────────────────────
// TAREFAS
// ─────────────────────────────────────────────
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  DONE
  FAILED
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)
  deadline    DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  assignedTeamId String?
  assignedTeam   Team?   @relation("TeamTasks", fields: [assignedTeamId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  templateId String?
  template   TaskTemplate? @relation(fields: [templateId], references: [id])

  comments    TaskComment[]
  attachments TaskAttachment[]
  history     TaskHistory[]

  @@map("tasks")
}

// ─────────────────────────────────────────────
// COMENTÁRIOS (Chat da tarefa)
// ─────────────────────────────────────────────
model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  mentions TaskCommentMention[]

  @@map("task_comments")
}

model TaskCommentMention {
  id String @id @default(cuid())

  commentId String
  comment   TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String

  @@map("task_comment_mentions")
}

// ─────────────────────────────────────────────
// ANEXOS
// ─────────────────────────────────────────────
model TaskAttachment {
  id        String   @id @default(cuid())
  filename  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_attachments")
}

// ─────────────────────────────────────────────
// HISTÓRICO / AUDIT LOG
// ─────────────────────────────────────────────
model TaskHistory {
  id        String   @id @default(cuid())
  action    String   // ex: "STATUS_CHANGED", "ASSIGNED", "PRIORITY_CHANGED"
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("task_history")
}

// ─────────────────────────────────────────────
// TEMPLATES DE TAREFAS
// ─────────────────────────────────────────────
model TaskTemplate {
  id          String       @id @default(cuid())
  name        String
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@map("task_templates")
}

// ─────────────────────────────────────────────
// NOTIFICAÇÕES INTERNAS
// ─────────────────────────────────────────────
enum NotificationType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENT
  TASK_MENTION
  TASK_DEADLINE_WARNING
  TASK_OVERDUE
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// CONFIGURAÇÕES DE NOTIFICAÇÃO (por empresa)
// ─────────────────────────────────────────────
model NotificationConfig {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  // WhatsApp (Evolution API)
  whatsappEnabled    Boolean @default(false)
  whatsappApiUrl     String?
  whatsappApiKey     String?
  whatsappGroupId    String?

  // Telegram
  telegramEnabled    Boolean @default(false)
  telegramBotToken   String?
  telegramChatId     String?

  // Resumo diário
  dailySummaryEnabled Boolean @default(false)
  dailySummaryTime    String  @default("08:00") // HH:MM

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("notification_configs")
}

// ─────────────────────────────────────────────
// GAMIFICAÇÃO
// ─────────────────────────────────────────────
enum BadgeType {
  SPEEDSTER        // 5 tarefas no prazo em uma semana
  ON_FIRE          // 30 dias sem atraso
  QUICK_STARTER    // Iniciou tarefa em menos de 1h
  WEEKLY_TOP       // Primeiro do ranking semanal
}

model Badge {
  id          String    @id @default(cuid())
  type        BadgeType @unique
  name        String
  description String
  icon        String

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  earnedAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ─────────────────────────────────────────────
// TAREFAS RECORRENTES
// ─────────────────────────────────────────────
enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model RecurringTask {
  id          String               @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority         @default(MEDIUM)
  frequency   RecurrenceFrequency

  // WEEKLY: dias da semana separados por vírgula "1,3,5" (0=Dom,1=Seg,...,6=Sáb)
  daysOfWeek  String?
  // MONTHLY: dia do mês (1-31)
  dayOfMonth  Int?

  // Atribuição automática ou manual
  autoAssign   Boolean @default(false)
  assignedToId String?
  assignedTo   User?   @relation("RecurringAssignee", fields: [assignedToId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  isActive  Boolean   @default(true)
  lastRunAt DateTime? // Última vez que gerou uma tarefa

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("RecurringCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recurring_tasks")
}
