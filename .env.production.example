# ──────────────────────────────────────────────────────────────────────
# TaskFlow — Variáveis de Ambiente de PRODUÇÃO
# Copie este arquivo para .env na VPS e preencha os valores
# ──────────────────────────────────────────────────────────────────────

# ── Banco de dados ───────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:SENHA_FORTE_AQUI@postgres:5432/taskflow"
POSTGRES_PASSWORD="SENHA_FORTE_AQUI"

# ── NextAuth ──────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="GERE_COM_OPENSSL_RAND_BASE64_32"
NEXTAUTH_URL="https://taskflow.ykaromarques.com"

# ── Resend (E-mail) ───────────────────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXX"
RESEND_FROM="TaskFlow <noreply@ykaromarques.com>"

# ── Cron jobs ────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
CRON_SECRET="GERE_COM_OPENSSL_RAND_HEX_32"

# ── MinIO (armazenamento de anexos) ───────────────────────────────────
MINIO_ENDPOINT="minio"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="taskflow"
MINIO_SECRET_KEY="SENHA_MINIO_AQUI"
MINIO_BUCKET="taskflow-files"
MINIO_PUBLIC_URL="https://taskflow.ykaromarques.com/storage"

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://taskflow.ykaromarques.com"
NODE_ENV="production"
